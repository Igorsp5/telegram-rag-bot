# ── Telegram API ──────────────────────────────────────────────
# Get these at https://my.telegram.org → API development tools
API_ID=YOUR_API_ID
API_HASH=YOUR_API_HASH

# Session string — generated once via: node session-generator.js
SESSION=YOUR_SESSION_STRING

# ── Server ────────────────────────────────────────────────────
PORT=3005

# Secret token to protect API endpoints (any random string, e.g. openssl rand -hex 16)
API_TOKEN=YOUR_SECRET_TOKEN
