    {
      "parameters": {
        "chatId": "={{ $json.chatId }}",
        "text": "В базе нет релевантных данных по вашему запросу.\n\n<i>Попробуйте переформулировать или уточнить тему.</i>",
        "additionalFields": {
          "appendAttribution": false,
          "parse_mode": "HTML"
        }
      },
      "id": "a6f43f85-aaf8-4946-8abc-b03fe810be71",
      "name": "Send No Data Reply",
      "type": "n8n-nodes-base.telegram",
      "position": [
        2352,
        528
      ],
      "typeVersion": 1.2,
      "webhookId": "d97a4160-c070-402f-8ac1-eb8de461fff3"
    },
    {
      "parameters": {
        "jsCode": "const { queryText, context, chatId, sourcesBlock, sourceIndex, sessionId } = $input.first().json;\n\nconst sourcesList = Object.entries(sourceIndex)\n  .sort((a, b) => a[1] - b[1])\n  .map(([ch, num]) => `(${num}) = ${ch}`)\n  .join(', ');\n\nconst systemPrompt = [\n  'You are a news analyst. You are given a user query and fragments of posts from Telegram channels.',\n  'Each source block is marked with a number: === [N] Channel Name ===',\n  '',\n  'Rules:',\n  '- Answer ONLY based on the provided data',\n  '- Do not invent facts that are not in the context',\n  '- Remove duplicates and ads',\n  '- Style: Bloomberg/RBC — concise, factual',\n  '- Format: maximum 5 bullet points, 1–2 sentences each',\n  '- After each point, include the source number in parentheses: (1), (2), etc.',\n  `- Source mapping: ${sourcesList}`,\n  '- If a point is based on multiple sources — include all: (1)(2)',\n  '- If the data is not relevant to the query — explicitly say so',\n  '- Current date: ' + new Date().toLocaleDateString('en-US')\n].join('\\n');\n\n// History from Merge History + Query\nconst history = $('Merge History + Query').first().json.history || [];\n\nconst userPrompt = `User query: ${queryText}\\n\\nSources from Telegram:\\n${context}`;\n\nconst body = {\n  model: 'gpt-4o-mini',\n  temperature: 0.3,\n  max_tokens: 1000,\n  messages: [\n    { role: 'system', content: systemPrompt },\n    ...history,\n    { role: 'user', content: userPrompt }\n  ]\n};\n\nreturn [{ json: { body, chatId, sourcesBlock, sessionId, queryText } }];"
      },
      "id": "9cfdc443-e042-4927-910f-3a52e2b779ad",
      "name": "Build OpenAI Request",
      "type": "n8n-nodes-base.code",
      "position": [
        2272,
        128
      ],
      "typeVersion": 2
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.openai.com/v1/chat/completions",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "openAiApi",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify($json.body) }}",
        "options": {}
      },
      "id": "557ea79b-0eab-43a4-b3ed-6c0ff6dee514",
      "name": "Call OpenAI",
      "type": "n8n-nodes-base.httpRequest",
      "position": [
        2480,
        128
      ],
      "typeVersion": 4.4,
      "credentials": {
        "openAiApi": {
          "id": "AJbpunHZHRIiM35i",
          "name": "OpenAI n8n_elest_v2"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const openAiResponse = $input.first().json;\nconst rawText = openAiResponse?.choices?.[0]?.message?.content || 'Не удалось получить ответ.';\n\nconst prev = $('Build OpenAI Request').first().json;\nconst { chatId, sourcesBlock, sessionId, queryText } = prev;\n\nconst safe = rawText\n  .replace(/&/g, '&amp;')\n  .replace(/</g, '&lt;')\n  .replace(/>/g, '&gt;')\n  .replace(/\\*\\*(.+?)\\*\\*/gs, '<b>$1</b>')\n  .replace(/\\*(.+?)\\*/gs, '<b>$1</b>')\n  .replace(/^#{1,3} (.+)$/gm, '<b>$1</b>');\n\nconst finalText = safe + sourcesBlock;\n\nreturn [{ json: { chatId, text: finalText, sessionId, queryText, answer: rawText } }];"
      },
      "id": "c48adb57-89cd-4b94-a8dc-b5aa50312cc6",
      "name": "Format Answer",
