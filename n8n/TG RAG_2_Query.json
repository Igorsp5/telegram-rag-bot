    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT message FROM n8n_telegram_aggregation_chat_histories\nWHERE session_id = '{{ $json.sessionId }}'\nORDER BY created_at ASC\nLIMIT 20;",
        "options": {}
      },
      "id": "1f1a3f81-f7a2-4bc0-9299-7b856fec2c93",
      "name": "Load History",
      "type": "n8n-nodes-base.postgres",
      "position": [
        624,
