    {
      "parameters": {
        "jsCode": "const trigger = $('Telegram Trigger').first().json;\nconst chatId  = trigger.message.chat.id;\nconst sessionId = String(chatId);\n\nlet queryText = ($json.text || '').trim();\nif (!queryText) {\n  queryText = (trigger.message.text || '').trim();\n}\n\nif (!queryText) throw new Error('Empty query');\n\nreturn [{ json: { queryText, chatId, sessionId } }];"
      },
      "id": "3e689e67-2389-4bc5-b208-6ff49b56bcd1",
