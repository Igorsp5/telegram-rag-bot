          "name": "railway"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Собираем историю из Load History\nconst historyRows = $input.all();\nconst history = historyRows\n  .map(r => {\n    try {\n      const msg = r.json.message;\n      return typeof msg === 'string' ? JSON.parse(msg) : msg;\n    } catch(e) { return null; }\n  })\n  .filter(Boolean);\n\n// Берём queryText/chatId/sessionId из Normalize Query Text\nconst normalized = $('Normalize Query Text').first().json;\n\nreturn [{ json: {\n  queryText:  normalized.queryText,\n  chatId:     normalized.chatId,\n  sessionId:  normalized.sessionId,\n  history\n} }];"
      },
      "id": "f3de9828-0328-42c1-9beb-d1c0e2f2a4f2",
      "name": "Merge History + Query",
      "type": "n8n-nodes-base.code",
      "position": [
        832,
        144
      ],
      "typeVersion": 2
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO n8n_telegram_aggregation_chat_histories (session_id, message)\nVALUES\n  ('{{ $json.sessionId }}', '{{ JSON.stringify({role:\"user\",content:$json.queryText}).replace(/'/g,\"''\") }}'::jsonb),\n  ('{{ $json.sessionId }}', '{{ JSON.stringify({role:\"assistant\",content:$json.answer}).replace(/'/g,\"''\") }}'::jsonb);",
        "options": {}
      },
      "id": "6ccb6836-de1b-4bdb-98f0-4d2a80f1487c",
      "name": "Save History",
      "type": "n8n-nodes-base.postgres",
