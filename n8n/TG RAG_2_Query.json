              "value": "text-embedding-3-small"
            },
            {
              "name": "input",
              "value": "=={{ $('Normalize Query Text').first().json.queryText }}"
            },
            {
              "name": "encoding_format",
              "value": "float"
            }
          ]
        },
        "options": {}
      },
      "id": "12a6f9ce-4689-4224-beb6-8301d415eeaa",
      "name": "Embed User Query",
      "type": "n8n-nodes-base.httpRequest",
      "position": [
        1232,
        144
      ],
      "typeVersion": 4.4
    },
    {
      "parameters": {
        "jsCode": "const cfgRows = $('Read Config').all();\nconst cfg = {};\ncfgRows.forEach(r => { cfg[r.json.key] = r.json.value; });\n\nconst retentionDays = parseInt(cfg.retention_days || '60');\nconst similarityMin = parseFloat(cfg.similarity_min || '0.25');\nconst topK          = parseInt(cfg.search_top_k || '15');\n\nconst embItem = $input.all().find(i => i.json?.data?.[0]?.embedding);\nconst vector  = embItem?.json?.data?.[0]?.embedding;\nif (!vector || !Array.isArray(vector)) throw new Error('No embedding');\n\nconst { queryText, chatId, sessionId } = $('Normalize Query Text').first().json;\n\nreturn [{ json: {\n  queryText,\n  chatId,\n  sessionId,\n  queryVector:  '[' + vector.join(',') + ']',\n  retentionDays,\n  similarityMin,\n  topK\n} }];"
      },
      "id": "a4490bf4-434d-4549-a536-b48ac09c7bfa",
      "name": "Merge Config + Vector",
      "type": "n8n-nodes-base.code",
      "position": [
        1424,
        144
      ],
      "typeVersion": 2
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT\n  msg_id,\n  channel_title,\n  text,\n  msg_date::date AS msg_date,\n  (1 - (embedding <=> '{{ $json.queryVector }}'::vector))::float AS similarity\nFROM tg_messages\nWHERE\n  msg_date >= NOW() - INTERVAL '{{ $json.retentionDays }} days'\n  AND embedding IS NOT NULL\n  AND (1 - (embedding <=> '{{ $json.queryVector }}'::vector)) >= {{ $json.similarityMin }}\nORDER BY embedding <=> '{{ $json.queryVector }}'::vector\nLIMIT {{ $json.topK }};",
        "options": {}
      },
      "id": "bc5b7a37-1bde-4732-a03a-3863ed988d46",
      "name": "Vector Search in Supabase",
      "type": "n8n-nodes-base.postgres",
      "position": [
        1632,
        144
      ],
      "typeVersion": 2.6,
      "alwaysOutputData": true,
      "credentials": {
        "postgres": {
          "id": "pTGjRU4YFxqJSp9K",
          "name": "railway"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const allRows = $input.all();\nconst rows = allRows.filter(r => r.json && r.json.msg_id);\nconst merged = $('Merge Config + Vector').first().json;\nconst { queryText, chatId, sessionId } = merged;\n\nif (rows.length === 0) {\n  return [{ json: { context: '', sourcesBlock: '', queryText, chatId, sessionId, hasData: false } }];\n}\n\n// Группируем по каналу, присваиваем номер источника\nconst byChannel = {};\nconst sourceIndex = {}; // channel_title -> номер (1, 2, 3...)\nlet srcNum = 1;\n\nrows.forEach(r => {\n  const rawTitle = r.json.channel_title || '';\n  const chId     = r.json.channel_id    || '';\n  const ch = /^\\d+$/.test(rawTitle.trim()) ? chId : rawTitle.trim();\n\n  if (!byChannel[ch]) {\n    byChannel[ch] = [];\n    sourceIndex[ch] = srcNum++;\n  }\n  byChannel[ch].push({\n    date: r.json.msg_date,\n    text: r.json.text.slice(0, 600)\n  });\n});\n\n// Контекст для AI — каждый фрагмент помечен номером источника\nlet context = '';\nfor (const [ch, msgs] of Object.entries(byChannel)) {\n  const num = sourceIndex[ch];\n  context += `\\n=== [${num}] ${ch} ===\\n`;\n  msgs.forEach(m => {\n    context += `[${m.date}] ${m.text}\\n`;\n  });\n}\n\n// Форматируем дату\nfunction fmtDate(raw) {\n  try {\n    return new Date(raw).toLocaleDateString('ru-RU', { day: 'numeric', month: 'short' });\n  } catch(e) { return raw; }\n}\n\n// Блок источников с номерами\nconst sourcesList = Object.entries(byChannel).map(([ch, msgs]) => {\n  const num = sourceIndex[ch];\n  const latest = msgs.map(m => m.date).sort().reverse()[0];\n  return `(${num}) ${ch} — ${fmtDate(latest)}`;\n});\n\nconst sourcesBlock = '\\n\\n<b>📡 Источники:</b>\\n' + sourcesList.join('\\n');\n\nreturn [{ json: {\n  context: context.trim(),\n  sourcesBlock,\n  sourceIndex,\n  queryText,\n  chatId,\n  sessionId,\n  hasData: context.trim().length > 0\n} }];"
      },
